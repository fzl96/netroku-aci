// Prisma schema — better-auth + SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id
  name            String
  email           String
  emailVerified   Boolean   @default(false)
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  username        String?
  displayUsername String?
  role            String?   @default("member")
  banned          Boolean?  @default(false)
  banReason       String?
  banExpires      DateTime?
  sessions        Session[]
  accounts        Account[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  userName  String
  action    String
  target    String?
  status    String
  detail    String?
  payload   Json?

  @@index([createdAt])
  @@index([userId])
  @@map("audit_log")
}

model ApicHost {
  id                  String              @id @default(cuid())
  name                String
  host                String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  lastInterfaceSyncAt DateTime?
  lastNodeSyncAt      DateTime?
  lastEpgSyncAt       DateTime?
  endpoints           Endpoint[]
  interfaces          InterfaceSnapshot[]
  nodes               NodeSnapshot[]
  hardware            HardwareComponent[]
  nodeSamples         NodeStatusSample[]
  epgs                EpgSnapshot[]

  @@unique([host])
  @@map("apic_host")
}

model Endpoint {
  id          String    @id @default(cuid())
  apicHostId  String
  apicHost    ApicHost  @relation(fields: [apicHostId], references: [id], onDelete: Cascade)
  mac         String
  ip          String
  vlan        String
  dn          String
  node        String
  interface   String
  epgDescr    String    @default("")
  isActive    Boolean   @default(true)
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  clearedAt   DateTime?

  @@index([apicHostId])
  @@index([apicHostId, mac, ip])
  @@index([apicHostId, lastSeenAt], name: "endpoint_host_last_seen_idx")
  @@index([apicHostId, isActive], name: "endpoint_host_active_idx")
  @@index([apicHostId, vlan], name: "endpoint_host_vlan_idx")
  @@index([apicHostId, node], name: "endpoint_host_node_idx")
  @@index([apicHostId, interface], name: "endpoint_host_interface_idx")
  @@map("endpoint")
}

model InterfaceSnapshot {
  id            String    @id @default(cuid())
  apicHostId    String
  apicHost      ApicHost  @relation(fields: [apicHostId], references: [id], onDelete: Cascade)
  dn            String
  node          String
  ifName        String
  usage         String    @default("")
  adminSt       String    @default("")
  operSt        String    @default("")
  operSpeed     String    @default("")
  description   String    @default("")
  lastLinkStChg DateTime?
  firstSeenAt   DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())

  samples InterfaceSample[]

  @@unique([apicHostId, dn])
  @@index([apicHostId])
  @@index([apicHostId, node, ifName], name: "interface_snapshot_host_node_if_idx")
  @@map("interface_snapshot")
}

model InterfaceSample {
  id          String            @id @default(cuid())
  apicHostId  String
  interfaceId String
  interface   InterfaceSnapshot @relation(fields: [interfaceId], references: [id], onDelete: Cascade)
  sampledAt   DateTime          @default(now())

  adminSt   String
  operSt    String
  operSpeed String

  rxBytes       BigInt
  rxPkts        BigInt
  rxErrors      BigInt
  rxDiscards    BigInt
  rxCrcErrors   BigInt
  rxAlignErrors BigInt

  txBytes    BigInt
  txPkts     BigInt
  txErrors   BigInt
  txDiscards BigInt

  dRxBytes       BigInt?
  dRxErrors      BigInt?
  dRxDiscards    BigInt?
  dRxCrcErrors   BigInt?
  dRxAlignErrors BigInt?
  dTxBytes       BigInt?
  dTxErrors      BigInt?
  dTxDiscards    BigInt?

  @@index([interfaceId, sampledAt])
  @@index([apicHostId, sampledAt])
  @@map("interface_sample")
}

model NodeSnapshot {
  id          String   @id @default(cuid())
  apicHostId  String
  apicHost    ApicHost @relation(fields: [apicHostId], references: [id], onDelete: Cascade)
  dn          String
  nodeId      String
  name        String   @default("")
  role        String   @default("")
  model       String   @default("")
  serial      String   @default("")
  version     String?
  fabricSt    String   @default("")
  state       String?
  podId       String?
  uptime      String?
  oobMgmtAddr String?
  present     Boolean  @default(true)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([apicHostId, dn])
  @@index([apicHostId])
  @@index([apicHostId, role])
  @@index([apicHostId, present, role], name: "node_snapshot_host_present_role_idx")
  @@index([apicHostId, present, fabricSt], name: "node_snapshot_host_present_fabric_idx")
  @@map("node_snapshot")
}

model HardwareComponent {
  id          String   @id @default(cuid())
  apicHostId  String
  apicHost    ApicHost @relation(fields: [apicHostId], references: [id], onDelete: Cascade)
  dn          String
  nodeId      String
  type        String
  name        String   @default("")
  operSt      String   @default("")
  healthy     Boolean  @default(true)
  model       String   @default("")
  serial      String   @default("")
  present     Boolean  @default(true)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([apicHostId, dn])
  @@index([apicHostId, nodeId])
  @@index([apicHostId, type])
  @@index([apicHostId, present, type], name: "hardware_component_host_present_type_idx")
  @@index([apicHostId, present, healthy], name: "hardware_component_host_present_healthy_idx")
  @@index([apicHostId, present, nodeId, type, healthy], name: "hardware_component_host_present_node_type_healthy_idx")
  @@map("hardware_component")
}

model NodeStatusSample {
  id               String   @id @default(cuid())
  apicHostId       String
  apicHost         ApicHost @relation(fields: [apicHostId], references: [id], onDelete: Cascade)
  sampledAt        DateTime @default(now())
  nodesTotal       Int
  nodesOnline      Int
  componentsTotal  Int
  componentsFailed Int

  @@index([apicHostId, sampledAt])
  @@map("node_status_sample")
}

model EpgSnapshot {
  id                String           @id @default(cuid())
  apicHostId        String
  apicHost          ApicHost         @relation(fields: [apicHostId], references: [id], onDelete: Cascade)
  dn                String
  name              String
  tenant            String
  appProfile        String
  description       String           @default("")
  bridgeDomain      String           @default("")
  pcTag             String           @default("")
  preferredGroup    Boolean          @default(false)
  isolation         Boolean          @default(false)
  domains           String[]
  providedContracts String[]
  consumedContracts String[]
  bindings          EpgPathBinding[]

  @@unique([apicHostId, dn])
  @@index([apicHostId, tenant])
  @@map("epg_snapshot")
}

model EpgPathBinding {
  id         String      @id @default(cuid())
  apicHostId String
  epgId      String
  epg        EpgSnapshot @relation(fields: [epgId], references: [id], onDelete: Cascade)
  dn         String
  pathTDn    String
  pod        String      @default("")
  node       String      @default("")
  port       String      @default("")
  pathType   String      @default("port")
  encap      String      @default("")
  mode       String      @default("trunk")

  @@unique([apicHostId, dn])
  @@index([apicHostId, node])
  @@index([epgId])
  @@map("epg_path_binding")
}

enum LegacyIngestFeature {
  health
  interfaces
  endpoints
}

model LegacyDevice {
  id                  String    @id @default(cuid())
  site                String
  siteKey             String
  hostname            String
  hostnameKey         String
  managementIp        String
  deviceType          String
  vendor              String?
  model               String?
  serialNumber        String?
  softwareVersion     String?
  location            String?
  active              Boolean   @default(true)
  firstSeenAt         DateTime  @default(now())
  lastSeenAt          DateTime  @default(now())
  lastHealthSyncAt    DateTime?
  lastInterfaceSyncAt DateTime?
  lastEndpointSyncAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  receipts         LegacyIngestReceipt[]
  healthSamples    LegacyHealthSample[]
  logs             LegacyLogEntry[]
  interfaces       LegacyInterfaceSnapshot[]
  interfaceSamples LegacyInterfaceSample[]
  endpoints        LegacyEndpoint[]

  @@unique([siteKey, hostnameKey])
  @@index([active, lastSeenAt])
  @@map("legacy_device")
}

model LegacyIngestReceipt {
  id          String              @id @default(cuid())
  runId       String
  deviceId    String
  device      LegacyDevice        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  feature     LegacyIngestFeature
  collectedAt DateTime
  receivedAt  DateTime            @default(now())
  payloadHash String
  inserted    Int                 @default(0)
  updated     Int                 @default(0)
  cleared     Int                 @default(0)
  samples     Int                 @default(0)

  healthSample     LegacyHealthSample?
  logs             LegacyLogEntry[]
  interfaceSamples LegacyInterfaceSample[]

  @@unique([runId, deviceId, feature])
  @@index([deviceId, collectedAt])
  @@map("legacy_ingest_receipt")
}

model LegacyHealthSample {
  id                 String              @id @default(cuid())
  deviceId           String
  device             LegacyDevice        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  receiptId          String              @unique
  receipt            LegacyIngestReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  collectedAt        DateTime
  uptime             String              @default("")
  cpuPercent         Float?
  memoryPercent      Float?
  storagePercent     Float?
  temperatureCelsius Float?
  fanStatuses        String[]
  psuStatuses        String[]

  @@index([deviceId, collectedAt])
  @@map("legacy_health_sample")
}

model LegacyLogEntry {
  id          String              @id @default(cuid())
  deviceId    String
  device      LegacyDevice        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  receiptId   String
  receipt     LegacyIngestReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  eventAt     DateTime?
  severity    String?
  message     String
  raw         String
  eventHash   String
  collectedAt DateTime

  @@unique([deviceId, eventHash])
  @@index([deviceId, collectedAt])
  @@map("legacy_log_entry")
}

model LegacyInterfaceSnapshot {
  id           String       @id @default(cuid())
  deviceId     String
  device       LegacyDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ifName       String
  ifNameKey    String
  description  String       @default("")
  ipAddress    String?
  prefixLength Int?
  mtu          Int?
  speed        String       @default("")
  adminSt      String       @default("")
  operSt       String       @default("")
  present      Boolean      @default(true)
  firstSeenAt  DateTime     @default(now())
  lastSeenAt   DateTime     @default(now())

  samples LegacyInterfaceSample[]

  @@unique([deviceId, ifNameKey])
  @@index([deviceId, present])
  @@map("legacy_interface_snapshot")
}

model LegacyInterfaceSample {
  id            String                  @id @default(cuid())
  deviceId      String
  device        LegacyDevice            @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  interfaceId   String
  interface     LegacyInterfaceSnapshot @relation(fields: [interfaceId], references: [id], onDelete: Cascade)
  receiptId     String
  receipt       LegacyIngestReceipt     @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  collectedAt   DateTime
  adminSt       String
  operSt        String
  speed         String
  inputErrors   BigInt
  outputErrors  BigInt
  crcErrors     BigInt
  dInputErrors  BigInt?
  dOutputErrors BigInt?
  dCrcErrors    BigInt?

  @@unique([receiptId, interfaceId])
  @@index([interfaceId, collectedAt])
  @@index([deviceId, collectedAt])
  @@map("legacy_interface_sample")
}

model LegacyEndpoint {
  id           String       @id @default(cuid())
  deviceId     String
  device       LegacyDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  mac          String
  ip           String?
  ipKey        String
  vlan         String
  vlanName     String       @default("")
  interface    String
  interfaceKey String
  learningType String       @default("")
  macFlag      String       @default("")
  isActive     Boolean      @default(true)
  firstSeenAt  DateTime     @default(now())
  lastSeenAt   DateTime     @default(now())
  clearedAt    DateTime?

  @@index([deviceId, isActive])
  @@index([deviceId, mac, ipKey])
  @@index([deviceId, interfaceKey])
  @@map("legacy_endpoint")
}
