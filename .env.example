NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL="postgresql://netroku:netroku@localhost:5432/netroku?schema=public"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# 32-byte hex key for encrypted fields. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
# Comma-separated origins allowed by Better Auth (LAN IPs, Tailscale, ts.net host)
TRUSTED_ORIGINS=http://localhost:3000
# Set to "true" only when served exclusively over HTTPS. Leave unset for HTTP/LAN access.
SECURE_COOKIES=
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Bearer token the external scheduler must send (Authorization: Bearer <token>)
# to call POST /api/cron/resync. Generate with: openssl rand -hex 32
SCHEDULER_TOKEN=
